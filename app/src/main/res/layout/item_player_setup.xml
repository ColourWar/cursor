<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/player_info_background"
    android:layout_marginVertical="4dp">

    <View
        android:id="@+id/viewPlayerColor"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="12dp"
        android:background="@drawable/player_color_indicator" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPlayerNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="玩家 1"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvPlayerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="玩家姓名"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <Button
        android:id="@+id/btnRemovePlayer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/remove_player"
        android:textSize="12sp"
        android:backgroundTint="@color/button_secondary"
        android:layout_gravity="center_vertical" />

</LinearLayout>